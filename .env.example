# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el .env real a git (ya está en .gitignore).

# --- Base de datos ---
# En local (sin Docker): mysql://usuario:password@127.0.0.1:3306/survey_db
# Con docker-compose: no hace falta tocar esta linea, docker-compose.yml
# la sobrescribe automaticamente usando MYSQL_ROOT_PASSWORD y MYSQL_DATABASE.
DATABASE_URL=mysql://root:CAMBIA_ESTA_PASSWORD@127.0.0.1:3306/survey_db

# Solo usadas por docker-compose para crear el contenedor de MySQL
MYSQL_ROOT_PASSWORD=CAMBIA_ESTA_PASSWORD
MYSQL_DATABASE=survey_db

# --- Autenticacion ---
# Genera un valor fuerte y unico para produccion, ej:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIA_ESTE_SECRETO

# --- Cloudinary (almacenamiento de archivos) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- CORS ---
# Dominio(s) del frontend, separados por coma. Ej:
# ALLOWED_ORIGINS=https://miapp.com,https://www.miapp.com
# Si el frontend se sirve bajo el mismo DOMAIN que la API (ver mas abajo, caso
# nginx + nip.io de este repo), las llamadas son same-origin y esto no bloquea
# nada aunque quede restrictivo. Ej: ALLOWED_ORIGINS=https://CAMBIA_ESTO.nip.io
ALLOWED_ORIGINS=*

# --- Nginx + HTTPS (solo usadas por docker-compose para los servicios "nginx" y "certbot") ---
# No tienes dominio propio? Usa nip.io: resuelve automaticamente a tu IP publica,
# sin configurar ningun DNS. Ej: si tu VPS es 203.0.113.42, pon:
# DOMAIN=203.0.113.42.nip.io
DOMAIN=CAMBIA_ESTO.nip.io
# Email de contacto para Let's Encrypt (avisos de expiracion, no se usa para nada mas)
LETSENCRYPT_EMAIL=tu-email@ejemplo.com

# --- Servidor (solo si se corre con "python main.py" en vez de uvicorn/Docker) ---
HOST=0.0.0.0
PORT=8000
RELOAD=false
